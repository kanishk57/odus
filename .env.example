# Odus — Environment Variables
# Copy this file to .env and fill in your values

# Google Gemini API Key (required)
# Get yours at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Model selection (optional — defaults shown)
ODUS_MODEL_FAST=gemini-2.5-flash
ODUS_MODEL_DEEP=gemini-2.5-pro

# Hotkey combo (optional — default: ctrl+shift+o)
ODUS_HOTKEY=ctrl+shift+o

# Safety: set to "true" to enable audit logging
ODUS_AUDIT_LOG=true
